{
  "name": "dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --mode web",
    "dev:chat-server": "node server/chat-server.mjs",
    "dev:app": "vite --mode app",
    "build": "tsc -b && vite build --mode web",
    "build:app": "tsc -b && vite build --mode app && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "build:app:signed": "tsc -b && vite build --mode app && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "@tailwindcss/vite": "^4.1.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^11.0.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "maplibre-gl": "^5.21.1",
    "prop-types": "^15.8.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-map-gl": "^8.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.10.1",
    "react-simple-maps": "^3.0.0",
    "redux": "^5.0.1",
    "redux-persist": "^6.0.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-simple-maps": "^3.0.6",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "sass": "^1.96.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.dashboard.app",
    "productName": "Dashboard",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release/${version}"
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
